<wpf:NoggogUserControl
    x:TypeArguments="profiles:ProfileVm"
    x:Class="Synthesis.Bethesda.GUI.Views.ProfileNugetsVersioningView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Synthesis.Bethesda.GUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpf="clr-namespace:Noggog.WPF;assembly=Noggog.WPF"
    xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:profiles="clr-namespace:Synthesis.Bethesda.GUI.ViewModels.Profiles"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <local:NugetVersioningView Grid.Row="0"
                x:Name="Mutagen"
                Title="Mutagen"
                HorizontalAlignment="Left" />
            <local:NugetVersioningView Grid.Row="2"
                x:Name="Synthesis"
                Title="Synthesis"
                HorizontalAlignment="Left" />
        </Grid>
        <ToggleButton Grid.Column="1"
                      x:Name="LockToggle"
                      Margin="5,0,0,0"
                      VerticalAlignment="Center"
                      ToolTip="Will disable all interaction with versioning systems, to help keep everything in its current state">
            <ToggleButton.Style>
                <Style TargetType="ToggleButton" BasedOn="{StaticResource BaseToggleButtonStyle}">
                    <Setter Property="Foreground" Value="{StaticResource MahApps.Brushes.Gray4}" />
                    <Setter Property="Content">
                        <Setter.Value>
                            <icon:PackIconFontAwesome Kind="UnlockKeyholeSolid"
                                                      Width="20"
                                                      Height="20"
                                                      VerticalAlignment="Center" />
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <icon:PackIconFontAwesome Kind="LockSolid"
                                                              Width="20"
                                                              Height="20"
                                                              VerticalAlignment="Center" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="False" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                        </MultiTrigger>
                    </Style.Triggers>
                </Style>
            </ToggleButton.Style>
        </ToggleButton>
    </Grid>
</wpf:NoggogUserControl>
