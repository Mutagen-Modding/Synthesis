<wpf:NoggogUserControl
    x:TypeArguments="git:GitPatcherVm"
    x:Class="Synthesis.Bethesda.GUI.Views.PatcherNugetsVersioningView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Synthesis.Bethesda.GUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpf="clr-namespace:Noggog.WPF;assembly=Noggog.WPF"
    xmlns:git="clr-namespace:Synthesis.Bethesda.GUI.ViewModels.Patchers.Git"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <local:NugetVersioningView Grid.Row="0"
            x:Name="Mutagen"
            Title="Mutagen"
            HorizontalAlignment="Left" />
        <local:NugetVersioningView Grid.Row="2"
            x:Name="Synthesis"
            Title="Synthesis"
            HorizontalAlignment="Left" />
    </Grid>
</wpf:NoggogUserControl>
