<UserControl x:Class="Synthesis.Bethesda.GUI.Views.Common.ReadMoreButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="200">
    <Button x:Name="ReadMoreBtn"
            Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Cursor="Hand"
            Background="Transparent"
            BorderThickness="0"
            Padding="0,8,12,8">
        <Button.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Opacity="0.5"
                ShadowDepth="0"
                Color="{StaticResource LightBlue}" />
        </Button.Effect>
        <Button.Style>
            <Style TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid HorizontalAlignment="Left" Background="Transparent">
                                <!-- Content -->
                                <StackPanel Orientation="Horizontal"
                                           HorizontalAlignment="Left"
                                           Margin="{TemplateBinding Padding}">
                                    <TextBlock x:Name="ReadMoreText"
                                              Text="Read More"
                                              FontSize="18"
                                              FontWeight="Bold"
                                              Foreground="{StaticResource LightBlueBrush}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0" />
                                    <icon:PackIconSimpleIcons x:Name="ReadMoreIcon"
                                                             Kind="ReadMe"
                                                             Width="18"
                                                             Height="18"
                                                             Margin="0,2,0,0"
                                                             Foreground="{StaticResource LightBlueBrush}"
                                                             VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ReadMoreText" Property="Foreground" Value="{StaticResource PaleBlueHoverBrush}" />
                                    <Setter TargetName="ReadMoreIcon" Property="Foreground" Value="{StaticResource PaleBlueHoverBrush}" />
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect
                                                BlurRadius="18"
                                                Opacity="0.8"
                                                ShadowDepth="0"
                                                Color="{StaticResource PaleBlueHover}" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Button.Style>
    </Button>
</UserControl>
