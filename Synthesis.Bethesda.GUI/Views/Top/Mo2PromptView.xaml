<wpf:NoggogUserControl
    x:TypeArguments="top:Mo2PromptVm" x:Class="Synthesis.Bethesda.GUI.Views.Mo2PromptView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Synthesis.Bethesda.GUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpf="clr-namespace:Noggog.WPF;assembly=Noggog.WPF"
    xmlns:top="clr-namespace:Synthesis.Bethesda.GUI.ViewModels.Top"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
            Margin="20,25,20,6"
            HorizontalAlignment="Center"
            FontSize="30"
            FontWeight="Bold"
            Foreground="{StaticResource SalmonBrush}"
            Text="Detected Mod Organizer 2" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="640"
                Margin="30,10"
                HorizontalAlignment="Center">
                
                <TextBlock FontSize="14"
                           Foreground="LightGray"
                           TextWrapping="Wrap">
                    MO2 uses a Virtual File System that can interfere with how Synthesis builds patchers
                </TextBlock>
                
                <TextBlock Margin="0,20,0,20"
                           FontSize="14">
                    <Hyperlink x:Name="FaqLink">Read the MO2 + Synthesis FAQ</Hyperlink>
                </TextBlock>
                
                <TextBlock FontSize="14"
                           Foreground="LightGray"
                           TextWrapping="Wrap">
                    It is recommend to enable "MO2 mode"
                </TextBlock>

                <CheckBox x:Name="EnableMo2ModeBox"
                    Margin="0,25,0,0"
                    Content="Enable MO2 mode"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="White" />

                <TextBlock Margin="24,6,0,25"
                    FontSize="12"
                    Foreground="Gray"
                    TextWrapping="Wrap"
                    Text="Can be changed any time in Advanced Settings" />
                
                <TextBlock FontSize="14"
                           Foreground="LightGray"
                           TextWrapping="Wrap">
                    This will make Synthesis more proactively refuse to build when inside Mo2, reminding you to launch Synthesis outside of MO2 once to complete the build.
                </TextBlock>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
            Padding="20,12"
            Background="{StaticResource TransparentGrayBackgroundBrush}">
            <Button x:Name="ConfirmButton"
                HorizontalAlignment="Right"
                MinWidth="120"
                Padding="20,6"
                Content="Confirm"
                FontSize="14" />
        </Border>
    </Grid>
</wpf:NoggogUserControl>
