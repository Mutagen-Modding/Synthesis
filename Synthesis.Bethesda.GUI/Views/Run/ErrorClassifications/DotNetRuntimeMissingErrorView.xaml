<UserControl x:Class="Synthesis.Bethesda.GUI.Views.ErrorClassifications.DotNetRuntimeMissingErrorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:common="clr-namespace:Synthesis.Bethesda.GUI.Views.Common"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0,0,0,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Error Type Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding ErrorType}"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{StaticResource SalmonBrush}"
                   Margin="0,0,0,10" />

        <!-- Required Version -->
        <TextBlock Grid.Row="1"
                   FontSize="16"
                   Foreground="{StaticResource PaleYellowBrush}"
                   Margin="0,0,0,15"
                   Visibility="{Binding HasRequiredVersion, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Run Text="Required: .NET " /><Run Text="{Binding RequiredVersion, Mode=OneWay}" FontWeight="Bold" />
        </TextBlock>

        <!-- Error Message with Read More Button -->
        <StackPanel Grid.Row="2"
                    Margin="0,0,0,15">
            <TextBlock Text="{Binding Message}"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="White"
                       Margin="0,0,0,10" />

            <common:ReadMoreButton Command="{Binding ReadMoreCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
