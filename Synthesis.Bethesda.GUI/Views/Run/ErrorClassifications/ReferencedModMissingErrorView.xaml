<UserControl x:Class="Synthesis.Bethesda.GUI.Views.ErrorClassifications.ReferencedModMissingErrorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Error Type Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding ErrorType}"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{StaticResource SalmonBrush}"
                   Margin="0,0,0,10" />

        <!-- Error Message -->
        <TextBlock Grid.Row="1"
                   FontSize="14"
                   TextWrapping="Wrap"
                   Foreground="White"
                   Margin="0,0,0,15">
            <Run Text="{Binding Message, Mode=OneWay}" />
            <LineBreak />
            <LineBreak />
            <Hyperlink x:Name="ReadMoreLink"
                       NavigateUri="https://github.com/Mutagen-Modding/Synthesis/discussions/382"
                       Foreground="{StaticResource LightBlueBrush}"
                       FontSize="20"
                       FontWeight="Bold">
                Read More
            </Hyperlink>
        </TextBlock>

        <!-- Missing Mod Info -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Missing Mod:"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{StaticResource SalmonBrush}"
                       Margin="0,0,0,3" />
            <TextBlock Text="{Binding MissingModKey}"
                       FontSize="15"
                       FontWeight="Bold"
                       FontFamily="Consolas"
                       Margin="10,0,0,0" />
        </StackPanel>

        <!-- Referenced By Info -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Referenced By Record:"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{StaticResource SalmonBrush}"
                       Margin="0,0,0,3" />
            <TextBlock Text="{Binding ReferencedBy}"
                       FontSize="14"
                       FontFamily="Consolas"
                       Foreground="White"
                       Margin="10,0,0,0" />
        </StackPanel>

        <!-- Load Order Header -->
        <TextBlock Grid.Row="4"
                   Text="Load Order at Time of Error:"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="{StaticResource SalmonBrush}"
                   Margin="0,0,0,5" />

        <!-- Load Order List -->
        <ScrollViewer Grid.Row="5"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding LoadOrder}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Margin="5,2">
                            <Run Text="{Binding ModKey, Mode=OneWay}"
                                 Foreground="White"
                                 FontFamily="Consolas" />
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
