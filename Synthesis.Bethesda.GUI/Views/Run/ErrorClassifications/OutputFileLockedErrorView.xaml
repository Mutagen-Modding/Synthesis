<UserControl x:Class="Synthesis.Bethesda.GUI.Views.ErrorClassifications.OutputFileLockedErrorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Margin="0,0,0,15">
        <!-- Error Type Header -->
        <TextBlock Text="{Binding ErrorType}"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{StaticResource SalmonBrush}"
                   Margin="0,0,0,10" />

        <!-- First part of message -->
        <TextBlock Text="The output patch file could not be exported because it is locked by another process:"
                   FontSize="14"
                   TextWrapping="Wrap"
                   Foreground="White"
                   Margin="0,0,0,8" />

        <!-- File Path -->
        <TextBlock Text="{Binding FilePath}"
                   FontSize="13"
                   FontFamily="Consolas"
                   Foreground="{StaticResource PaleYellowBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15" />

        <!-- Rest of message -->
        <TextBlock FontSize="14"
                   TextWrapping="Wrap"
                   Foreground="White">
            <Run Text="Please close any programs that may have this file open, such as:" />
            <LineBreak />
            <Run Text="  - xEdit (SSEEdit, FO4Edit, etc.)" />
            <LineBreak />
            <Run Text="  - Creation Kit" />
            <LineBreak />
            <Run Text="  - Other mod tools or file managers" />
            <LineBreak /><LineBreak />
            <Run Text="Then try running Synthesis again." />
        </TextBlock>
    </StackPanel>
</UserControl>
