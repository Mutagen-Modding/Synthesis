<wpf:NoggogUserControl x:Class="Synthesis.Bethesda.GUI.Views.ErrorClassifications.LibraryVersionMismatchErrorView"
             x:TypeArguments="errors:LibraryVersionMismatchErrorVm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:common="clr-namespace:Synthesis.Bethesda.GUI.Views.Common"
             xmlns:local="clr-namespace:Synthesis.Bethesda.GUI.Views"
             xmlns:wpf="clr-namespace:Noggog.WPF;assembly=Noggog.WPF"
             xmlns:errors="clr-namespace:Synthesis.Bethesda.GUI.ViewModels.Errors"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0,0,0,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Error Type Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding ErrorType}"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{StaticResource SalmonBrush}"
                   Margin="0,0,0,10" />

        <!-- Error Message -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Message}"
                   FontSize="14"
                   TextWrapping="Wrap"
                   Foreground="White"
                   Margin="0,0,0,15" />

        <!-- Read More Button -->
        <common:ReadMoreButton Grid.Row="2"
                               Command="{Binding ReadMoreCommand}" />

        <!-- Versioning Settings Section -->
        <StackPanel Grid.Row="3" Margin="0,15,0,0">
            <!-- Profile Versioning -->
            <TextBlock Text="Profile Versioning Settings"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PurpleForegroundBrush}"
                       Margin="0,0,0,8" />

            <local:ProfileNugetsVersioningView DataContext="{Binding ProfileVm}" />

            <!-- Patcher Versioning (only shown for Git patchers) -->
            <StackPanel x:Name="PatcherVersioningPanel" Margin="0,15,0,0">
                <TextBlock Text="Patcher Versioning Settings"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PurpleForegroundBrush}"
                           Margin="0,0,0,8" />

                <local:PatcherNugetsVersioningView DataContext="{Binding PatcherVm}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</wpf:NoggogUserControl>
