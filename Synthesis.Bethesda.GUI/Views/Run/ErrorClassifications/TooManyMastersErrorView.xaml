<UserControl x:Class="Synthesis.Bethesda.GUI.Views.ErrorClassifications.TooManyMastersErrorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:common="clr-namespace:Synthesis.Bethesda.GUI.Views.Common"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0,0,0,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Error Type Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding ErrorType}"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{StaticResource SalmonBrush}"
                   Margin="0,0,0,10" />

        <!-- Error Message with Read More Button -->
        <StackPanel Grid.Row="1"
                    Margin="0,0,0,15">
            <TextBlock Text="{Binding Message}"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="White"
                       Margin="0,0,0,10" />

            <common:ReadMoreButton Command="{Binding ReadMoreCommand}" />
        </StackPanel>

        <!-- Potential Fix Section (visible only if ShowPotentialFix is true) -->
        <StackPanel Grid.Row="2"
                    Margin="0,0,0,10"
                    Visibility="{Binding ShowPotentialFix, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Potential Fix"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{StaticResource SalmonBrush}"
                       Margin="0,0,0,5" />

            <TextBlock Text="Consider enabling 'Split If Max Masters Exceeded' in your profile settings to automatically split the output into multiple plugins."
                       FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="White"
                       Margin="0,0,0,10" />

            <CheckBox Content="Split If Max Masters Exceeded"
                      IsChecked="{Binding ProfileVm.SplitIfMaxMastersExceeded}"
                      FontSize="14"
                      Foreground="White"
                      Margin="0,0,0,0" />
        </StackPanel>

        <!-- Old Patcher Warning Section (visible only if ShowOldPatcherWarning is true) -->
        <StackPanel Grid.Row="3"
                    Margin="0,0,0,10"
                    Visibility="{Binding ShowOldPatcherWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Older Patcher Detected"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{StaticResource SalmonBrush}"
                       Margin="0,0,0,5" />

            <TextBlock FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="White"
                       Margin="0,0,0,10">
                <Run>This patcher is using Synthesis version</Run>
                <Run Text="{Binding PatcherSynthesisVersion, Mode=OneWay}" FontWeight="Bold" />
                <Run>, which does not support the split masters feature (requires v0.36.0+).</Run>
            </TextBlock>

            <TextBlock Text="To resolve this issue:"
                       FontSize="14"
                       Foreground="White"
                       Margin="0,0,0,5" />

            <TextBlock FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="LightGray"
                       Margin="10,0,0,5">
                <Run FontWeight="Bold">1.</Run>
                <Run>Move this patcher earlier in your group - Place it before patchers that might cause the master count to exceed the limit.</Run>
            </TextBlock>

            <TextBlock FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="LightGray"
                       Margin="10,0,0,10">
                <Run FontWeight="Bold">2.</Run>
                <Run>Upgrade the patcher to use the latest Synthesis version.</Run>
            </TextBlock>

            <Button Content="Learn More About Versioning"
                    Command="{Binding VersioningDocsCommand}"
                    HorizontalAlignment="Left"
                    Padding="10,5"
                    Margin="0,0,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
