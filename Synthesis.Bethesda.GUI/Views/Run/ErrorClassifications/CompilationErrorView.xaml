<wpf:NoggogUserControl x:Class="Synthesis.Bethesda.GUI.Views.ErrorClassifications.CompilationErrorView"
             x:TypeArguments="errors:CompilationErrorVm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:common="clr-namespace:Synthesis.Bethesda.GUI.Views.Common"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:Synthesis.Bethesda.GUI.Views"
             xmlns:wpf="clr-namespace:Noggog.WPF;assembly=Noggog.WPF"
             xmlns:errors="clr-namespace:Synthesis.Bethesda.GUI.ViewModels.Errors"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0,0,0,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Error Type Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding ErrorType}"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{StaticResource SalmonBrush}"
                   Margin="0,0,0,10" />

        <!-- Error Message -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Message}"
                   FontSize="14"
                   TextWrapping="Wrap"
                   Foreground="White"
                   Margin="0,0,0,15" />

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">
            <!-- Read More Button -->
            <common:ReadMoreButton Command="{Binding ReadMoreCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,5">
            <!-- Set to Match Button -->
            <Button x:Name="SetToMatchButton"
                    Command="{Binding SetToMatchCommand}"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0,8,12,8">
                <Button.Effect>
                    <DropShadowEffect
                        BlurRadius="15"
                        Opacity="0.5"
                        ShadowDepth="0"
                        Color="{StaticResource LightBlue}" />
                </Button.Effect>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Grid HorizontalAlignment="Left" Background="Transparent">
                                        <StackPanel Orientation="Horizontal"
                                                   HorizontalAlignment="Left"
                                                   Margin="{TemplateBinding Padding}">
                                            <TextBlock x:Name="BtnText"
                                                      Text="Set to Match"
                                                      FontSize="18"
                                                      FontWeight="Bold"
                                                      Foreground="{StaticResource LightBlueBrush}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0" />
                                            <icon:PackIconMaterial x:Name="BtnIcon"
                                                                 Kind="SwapHorizontal"
                                                                        Width="18"
                                                                        Height="18"
                                                                        Margin="0,2,0,0"
                                                                        Foreground="{StaticResource LightBlueBrush}"
                                                                        VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnText" Property="Foreground" Value="{StaticResource PaleBlueHoverBrush}" />
                                            <Setter TargetName="BtnIcon" Property="Foreground" Value="{StaticResource PaleBlueHoverBrush}" />
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect
                                                        BlurRadius="18"
                                                        Opacity="0.8"
                                                        ShadowDepth="0"
                                                        Color="{StaticResource PaleBlueHover}" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Open Issue Button -->
            <Button x:Name="OpenIssueButton"
                    Command="{Binding OpenIssueCommand}"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0,8,12,8"
                    Margin="20,0,0,0">
                <Button.Effect>
                    <DropShadowEffect
                        BlurRadius="15"
                        Opacity="0.5"
                        ShadowDepth="0"
                        Color="{StaticResource LightBlue}" />
                </Button.Effect>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Grid HorizontalAlignment="Left" Background="Transparent">
                                        <StackPanel Orientation="Horizontal"
                                                   HorizontalAlignment="Left"
                                                   Margin="{TemplateBinding Padding}">
                                            <TextBlock x:Name="BtnText"
                                                      Text="Open Issue"
                                                      FontSize="18"
                                                      FontWeight="Bold"
                                                      Foreground="{StaticResource LightBlueBrush}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0" />
                                            <icon:PackIconSimpleIcons x:Name="BtnIcon"
                                                                     Kind="GitHub"
                                                                     Width="18"
                                                                     Height="18"
                                                                     Margin="0,2,0,0"
                                                                     Foreground="{StaticResource LightBlueBrush}"
                                                                     VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnText" Property="Foreground" Value="{StaticResource PaleBlueHoverBrush}" />
                                            <Setter TargetName="BtnIcon" Property="Foreground" Value="{StaticResource PaleBlueHoverBrush}" />
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect
                                                        BlurRadius="18"
                                                        Opacity="0.8"
                                                        ShadowDepth="0"
                                                        Color="{StaticResource PaleBlueHover}" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Patcher Versioning -->
        <StackPanel x:Name="PatcherVersioningPanel" Grid.Row="4" Margin="0,15,0,0">
            <TextBlock Text="Patcher Versioning Settings"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PurpleForegroundBrush}"
                       Margin="0,0,0,8" />

            <local:PatcherNugetsVersioningView DataContext="{Binding PatcherVm}" />
        </StackPanel>
    </Grid>
</wpf:NoggogUserControl>
